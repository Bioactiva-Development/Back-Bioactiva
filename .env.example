FRONTEND_URL=http://localhost:5173
DATABASE_URL=
# Tuning del pool de conexiones de Postgres (todos opcionales).
# DATABASE_POOL_MAX -> conexiones max por instancia (default 5). Si varios
#   entornos comparten el mismo servidor, repartir el cupo: suma <= max_connections.
# DATABASE_APP_NAME -> identifica las conexiones en pg_stat_activity.
DATABASE_POOL_MAX= #default 5
DATABASE_APP_NAME= #default "bioactiva-backend-<NODE_ENV>"
# DATABASE_POOL_IDLE_MS= #default 10000
# DATABASE_POOL_CONN_TIMEOUT_MS= #default 10000
# DATABASE_POOL_MAX_USES= #default 7500
# DATABASE_IDLE_TX_TIMEOUT_MS= #default 30000
REDIS_URL=

JWT_SECRET=
JWT_EXPIRES_IN=
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=
JWT_ISSUER=
JWT_AUDIENCE=
BCRYPT_SALT_ROUNDS=

ADMIN_EMAIL=
ADMIN_PASSWORD=
REFRESH_TOKEN_COOKIE_NAME= #can be empty in development, but should be set in production for security reasons
NODE_ENV= #example "development" or "production"
ALLOWED_EMAIL_DOMAINS= #example "example.com,anotherdomain.com"

RESEND_TOKEN=

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
MAIL_FROM=no-reply@back-bioactiva.com #just testing, should be set to a valid email in production
MAIL_FROM_NAME=Bioactiva
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
MICROSOFT_SCOPES=
MAIL_PROVIDER=mock #mock|smtp|graph

# SUNAT / Web Scraper
PYTHON_SCRAPER_URL= #default "http://localhost:8000"

# reCAPTCHA Enterprise (protege solo el endpoint POST /auth/login)
GOOGLE_APPLICATION_CREDENTIALS= #path to the Google service account credentials JSON file for reCAPTCHA verification, example "./credentials/recaptcha-account.json"
RECAPTCHA_ENABLED=false #true para verificar contra Google; false hace bypass (dev/CI sin credenciales)
RECAPTCHA_MODE=checkbox #checkbox (v2: solo valida el token) | score (v3/Enterprise: valida action + score)
GOOGLE_CLOUD_PROJECT_ID= #ID del proyecto en Google Cloud (requerido si RECAPTCHA_ENABLED=true)
RECAPTCHA_SITE_KEY= #site key pública de reCAPTCHA (requerido si RECAPTCHA_ENABLED=true)
RECAPTCHA_MIN_SCORE=0.5 #umbral mínimo de score, solo aplica en RECAPTCHA_MODE=score (0.0 - 1.0)
RECAPTCHA_LOGIN_ACTION=login #nombre de la acción esperada en el token, solo aplica en RECAPTCHA_MODE=score
# DECOLECTA_API_SUNAT_TOKEN=
# APIPERU_TOKEN=
